# Public runtime config (VITE_* only — do not also set NUXT_PUBLIC_*).
# Docker maps these to Nuxt runtimeConfig automatically.

# Supabase
VITE_SUPABASE_URL="https://supabase.example.com"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# App
VITE_ENV="production"
# Public site URL used for sitemap/RSS/canonical/i18n base
VITE_SITE_URL="https://blog.example.com"
# Optional default locale (en, ku, ar, es, fr, de)
# VITE_SITE_LOCALE="en"
# Optional Twitter/X @handle for cards
# VITE_TWITTER_SITE="@pluma"
# Optional feeds cache TTL (ms)
# VITE_FEEDS_CACHE_TTL_MS=300000
