{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/sitemap", "destination": "/api/sitemap" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    { "source": "/rss", "destination": "/api/rss" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/env", "destination": "/api/env" },
    { "source": "/healthz", "destination": "/api/health" },
    { "source": "/readyz", "destination": "/api/ready" },
    {
      "source": "/((?!api(?:/|$)|assets(?:/|$)|favicon\\.png|favicon\\.ico).*)",
      "destination": "/api/document?path=/$1"
    }
  ]
}
